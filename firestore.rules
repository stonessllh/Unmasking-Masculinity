rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(authorId) {
      return isSignedIn() && request.auth.uid == authorId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Posts Rules ---
    function isValidPost(data) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 300 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 10000 &&
             data.authorId == request.auth.uid &&
             data.createdAt == request.time;
    }

    match /posts/{postId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous' && isValidPost(incoming());
      allow update: if false; 
      allow delete: if isOwner(existing().authorId);

      // --- Replies Rules ---
      function isValidReply(data) {
        return data.keys().hasAll(['postId', 'content', 'authorId', 'createdAt']) &&
               data.keys().size() == 4 &&
               data.postId == postId &&
               data.content is string && data.content.size() > 0 && data.content.size() <= 3000 &&
               data.authorId == request.auth.uid &&
               data.createdAt == request.time;
      }

      match /replies/{replyId} {
        allow list, get: if isSignedIn();
        allow create: if isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous' && isValidReply(incoming());
        allow update: if false;
        allow delete: if isOwner(existing().authorId);
      }
    }

    // --- Showcase Rules ---
    function isValidShowcase(data) {
      return data.keys().hasAll(['title', 'url', 'description', 'type', 'authorId', 'createdAt']) &&
             data.title is string && data.title.size() > 0 &&
             data.url is string && data.url.size() > 0 &&
             data.description is string && data.description.size() > 0 &&
             data.type in ['video', 'report'] &&
             data.authorId == request.auth.uid &&
             data.createdAt == request.time;
    }

    match /showcase/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous' && isValidShowcase(incoming());
      allow delete: if isOwner(existing().authorId);
    }
  }
}
